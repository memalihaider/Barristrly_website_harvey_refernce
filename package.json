{
  "name": "barristrly",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @barristrly/web",
    "build": "npm run build -w @barristrly/web",
    "start": "npm run start -w @barristrly/web",
    "lint": "npm run lint -w @barristrly/web",
    "typecheck": "npm run typecheck -w @barristrly/web",
    "test:app": "bash scripts/run-test.sh",
    "test:smoke": "bash scripts/run-test.sh --smoke",
    "test:prod": "bash scripts/run-test.sh --build",
    "seed:test-users": "node scripts/seed-test-users.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
